<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ReMedia.App.Avalonia.ViewModels"
        x:Class="ReMedia.App.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="960" Height="720"
        Title="ReMedia (Avalonia)">

  <Grid RowDefinitions="Auto,*,Auto,Auto,Auto,160" Margin="12">

    <!-- Input row -->
    <Border Grid.Row="0" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,10">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto">
        <TextBlock Grid.Column="0" Text="Input:" VerticalAlignment="Center" Margin="0,0,8,0" />
        <TextBox Grid.Column="1" Text="{Binding InputPath}" Watermark="Path to a media file" Margin="0,0,8,0" />
        <Button Grid.Column="2" Content="Browse…" Command="{Binding BrowseInputCommand}" Margin="0,0,8,0" />
        <Button Grid.Column="3" Content="Probe" Command="{Binding ProbeCommand}" />
      </Grid>
    </Border>

    <!-- Tracks -->
    <Border Grid.Row="1" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4" Margin="0,0,0,10">
      <DataGrid ItemsSource="{Binding Tracks}"
                IsReadOnly="False"
                AutoGenerateColumns="False"
                GridLinesVisibility="Horizontal">
        <DataGrid.Columns>
          <DataGridCheckBoxColumn Header="Export" Binding="{Binding Selected}" Width="70" />
          <DataGridTextColumn Header="#" Binding="{Binding StreamIndex}" Width="50" IsReadOnly="True" />
          <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="100" IsReadOnly="True" />
          <DataGridTextColumn Header="Codec" Binding="{Binding Codec}" Width="120" IsReadOnly="True" />
          <DataGridTextColumn Header="Lang" Binding="{Binding Language}" Width="70" IsReadOnly="True" />
          <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" IsReadOnly="True" />
          <DataGridTextColumn Header="Ch" Binding="{Binding Channels}" Width="60" IsReadOnly="True" />
          <DataGridTextColumn Header="Sample rate" Binding="{Binding SampleRate}" Width="120" IsReadOnly="True" />
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <!-- Export controls -->
    <Border Grid.Row="2" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,10">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
        <TextBlock Grid.Column="0" Text="Output:" VerticalAlignment="Center" Margin="0,0,8,0" />
        <TextBox Grid.Column="1" Text="{Binding OutputFolder}" Watermark="Output folder" Margin="0,0,8,0" />
        <Button Grid.Column="2" Content="Browse…" Command="{Binding BrowseOutputCommand}" Margin="0,0,8,0" />
        <CheckBox Grid.Column="3" Content="Mux to MKV" IsChecked="{Binding MuxToMkv}" VerticalAlignment="Center" Margin="0,0,8,0" />
        <Button Grid.Column="4" Content="Export" Command="{Binding ExportCommand}" />
      </Grid>
    </Border>

    <!-- Progress -->
    <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
      <ProgressBar Grid.Column="0" Minimum="0" Maximum="100" Value="{Binding Progress}" Height="16" Margin="0,0,8,0" />
      <TextBlock Grid.Column="1" Text="{Binding Status}" VerticalAlignment="Center" />
    </Grid>

    <TextBlock Grid.Row="4" Text="Log" FontWeight="SemiBold" Margin="0,0,0,6" />

    <!-- Log -->
    <Border Grid.Row="5" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4">
      <TextBox Text="{Binding Log}"
               IsReadOnly="True"
               AcceptsReturn="True"
               TextWrapping="Wrap"
               FontFamily="Cascadia Code, Consolas, monospace"
               VerticalContentAlignment="Top" />
    </Border>
  </Grid>
</Window>
