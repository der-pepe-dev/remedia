<Window x:Class="ReMedia.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ReMedia Sync"
        Width="1200"
        Height="700"
        MinWidth="900"
        MinHeight="520"
        AllowDrop="True"
        Drop="OnFileDrop"
        DragOver="OnDragOver">

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Input -->
        <Border Grid.Row="0" Padding="6" Margin="0,0,0,4" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4">
            <StackPanel>
                <DockPanel>
                    <Button DockPanel.Dock="Right" Width="75" Content="Browse…" Command="{Binding BrowseInputCommand}" Margin="5,0,0,0" />
                    <Button DockPanel.Dock="Right" Width="110" Content="Probe" Command="{Binding ProbeCommand}" Margin="5,0,0,0" />
                    <TextBlock Text="Input file" FontWeight="SemiBold" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBox Text="{Binding InputPath, UpdateSourceTrigger=PropertyChanged}" MinWidth="300" />
                </DockPanel>
                <DockPanel Margin="0,3,0,0">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="5,0,0,0">
                        <Button Width="68" Content="Add part" Command="{Binding AddPartCommand}" />
                        <Button Width="68" Content="Remove" Command="{Binding RemovePartCommand}" Margin="3,0,0,0" />
                    </StackPanel>
                    <TextBlock Text="Parts:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,6,0" />
                    <ItemsControl ItemsSource="{Binding InputParts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F0F0F0" CornerRadius="3" Padding="4,1" Margin="0,0,4,0">
                                    <TextBlock Text="{Binding}" FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="200" ToolTip="{Binding}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </StackPanel>
        </Border>

        <!-- Timing + Probe summary -->
        <Grid Grid.Row="1" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="6" Margin="0,0,4,0" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4">
                <StackPanel>
                    <TextBlock Text="Timing analysis" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="22" />
                            <RowDefinition Height="22" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="18" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Source FPS" VerticalAlignment="Center" />
                        <ComboBox Grid.Row="0" Grid.Column="1" IsEditable="True"
                                  Text="{Binding SourceFpsText, UpdateSourceTrigger=LostFocus}"
                                  ItemsSource="{Binding SourceFpsPresets}"
                                  SelectedItem="{Binding SelectedSourceFpsPreset}"
                                  DisplayMemberPath="DisplayName" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Target FPS" VerticalAlignment="Center" />
                        <ComboBox Grid.Row="1" Grid.Column="1" IsEditable="True"
                                  Text="{Binding TargetFpsText, UpdateSourceTrigger=LostFocus}"
                                  ItemsSource="{Binding TargetFpsPresets}"
                                  SelectedItem="{Binding SelectedTargetFpsPreset}"
                                  DisplayMemberPath="DisplayName" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Original duration" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding OriginalDurationText}" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Destination duration" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DestinationDurationText}" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Stretch factor" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding StretchFactorText}" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Audio tempo" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding AudioTempoText}" VerticalAlignment="Center" />
                    </Grid>
                    <Button Margin="0,4,0,0" Width="150" Height="22" FontSize="11"
                            Content="Calculate timing" Command="{Binding CalculateTimingCommand}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Padding="6" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4">
                <StackPanel>
                    <TextBlock Text="Probe summary" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3" />
                    <TextBlock Text="{Binding ProbeSummary}" TextWrapping="Wrap" FontSize="11" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Tracks -->
        <Border Grid.Row="2" Padding="6" Margin="0,0,0,4" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                    <TextBlock Text="Tracks" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Measure loudness" Command="{Binding MeasureLoudnessCommand}" Width="120" Height="22" FontSize="11" />
                        <Button Content="Select all" Command="{Binding SelectAllTracksCommand}" Width="74" Height="22" FontSize="11" Margin="5,0,0,0" />
                        <Button Content="Deselect all" Command="{Binding DeselectAllTracksCommand}" Width="74" Height="22" FontSize="11" Margin="3,0,0,0" />
                    </StackPanel>
                </DockPanel>
                <DataGrid ItemsSource="{Binding Tracks}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          IsReadOnly="False"
                          RowHeight="20"
                          FontSize="11">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="Export" Binding="{Binding Selected}" Width="55" />
                        <DataGridTextColumn Header="#" Binding="{Binding StreamIndex}" Width="35" IsReadOnly="True" />
                        <DataGridTextColumn Header="Type" Binding="{Binding AssetType}" Width="70" IsReadOnly="True" />
                        <DataGridTextColumn Header="Codec" Binding="{Binding CodecName}" Width="90" IsReadOnly="True" />
                        <DataGridTextColumn Header="Detail" Binding="{Binding DetailDisplay}" Width="90" IsReadOnly="True" />
                        <DataGridTextColumn Header="Loudness" Binding="{Binding LoudnessDisplay}" Width="80" IsReadOnly="True" />
                        <DataGridTextColumn Header="Gain" Binding="{Binding ClippingDisplay}" Width="70" IsReadOnly="True" />
                        <DataGridTextColumn Header="Lang" Binding="{Binding Language}" Width="50" IsReadOnly="True" />
                        <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" IsReadOnly="True" />
                        <DataGridTextColumn Header="Flags" Binding="{Binding FlagsDisplay}" Width="80" IsReadOnly="True" />
                        <DataGridTemplateColumn Header="Output Codec" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding OutputCodec}" Padding="2" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox IsEditable="True"
                                              Text="{Binding OutputCodec, UpdateSourceTrigger=PropertyChanged}"
                                              ItemsSource="{Binding AvailableCodecs}"
                                              IsDropDownOpen="True" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Ext" Binding="{Binding OutputContainer}" Width="60" IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- Progress -->
        <DockPanel Grid.Row="3" Margin="0,0,0,4">
            <TextBlock DockPanel.Dock="Right" Text="{Binding StatusText}"
                       FontSize="10" Foreground="#666666"
                       VerticalAlignment="Center" Margin="6,0,0,0"
                       MaxWidth="400" TextTrimming="CharacterEllipsis" />
            <ProgressBar Height="3"
                         Minimum="0"
                         Maximum="{Binding ProgressMax, Mode=OneWay}"
                         Value="{Binding ProgressValue, Mode=OneWay}"
                         IsIndeterminate="{Binding IsProgressIndeterminate}" />
        </DockPanel>

        <!-- Export + Log -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="6" Margin="0,0,4,0" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4">
                <StackPanel>
                    <TextBlock Text="Export" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3" />
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Width="75" Height="20" Content="Browse…" Command="{Binding BrowseOutputCommand}" Margin="5,0,0,0" />
                        <TextBox Text="{Binding OutputFolder}" Height="20" />
                    </DockPanel>
                    <CheckBox Content="Export chapters" IsChecked="{Binding ExportChapters}" Margin="0,4,0,0" />
                    <CheckBox Content="Apply timing conversion" IsChecked="{Binding ApplyTiming}" Margin="0,2,0,0" />
                    <CheckBox Content="Mux to .mkv" IsChecked="{Binding MuxToMkv}" Margin="0,2,0,0" />
                    <DockPanel Margin="0,2,0,0">
                        <Button DockPanel.Dock="Right" Width="75" Height="20" Content="Browse…" Command="{Binding BrowseDestinationCommand}" Margin="5,0,0,0" />
                        <Button DockPanel.Dock="Right" Width="60" Height="20" Content="Loudness" Command="{Binding MeasureDestinationLoudnessCommand}" Margin="3,0,0,0" />
                        <Button DockPanel.Dock="Right" Width="45" Height="20" Content="Probe" Command="{Binding ProbeDestinationCommand}" Margin="3,0,0,0" />
                        <TextBlock Text="Dest:" VerticalAlignment="Center" Margin="0,0,5,0" />
                        <TextBox Text="{Binding DestinationMasterPath}" Height="20" />
                    </DockPanel>
                    <DockPanel Margin="0,2,0,0">
                        <CheckBox Content="Normalize loudness" IsChecked="{Binding NormalizeLoudness}" VerticalAlignment="Center" />
                        <TextBlock Text="Target:" VerticalAlignment="Center" Margin="10,0,5,0" />
                        <TextBox Text="{Binding TargetLufsText, UpdateSourceTrigger=LostFocus}" Width="44" Height="20" />
                        <TextBlock Text="LUFS" VerticalAlignment="Center" Margin="3,0,0,0" />
                    </DockPanel>
                    <DockPanel Margin="0,2,0,0">
                        <Button DockPanel.Dock="Right" Width="85" Height="20" Content="Analyze sync" Command="{Binding AnalyzeSyncCommand}" Margin="5,0,0,0" />
                        <TextBlock Text="Sync offset:" VerticalAlignment="Center" Margin="0,0,5,0" />
                        <TextBlock Text="{Binding SyncOffsetText}" VerticalAlignment="Center" FontFamily="Consolas" FontSize="10" />
                    </DockPanel>
                    <WrapPanel Margin="0,5,0,0">
                        <Button Width="150" Height="22" Content="Export selected" Command="{Binding ExportCommand}" />
                        <Button Width="90" Height="22" Content="Cancel" Command="{Binding CancelCommand}" Margin="6,0,0,0" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Padding="6" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                        <TextBlock Text="Log" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Content="Clear" Command="{Binding ClearLogCommand}" Width="55" Height="20" FontSize="11" HorizontalAlignment="Right" />
                    </DockPanel>
                    <TextBox x:Name="LogTextBox"
                             Text="{Binding LogText}"
                             FontFamily="Consolas" FontSize="11"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             TextChanged="LogTextBox_TextChanged" />
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
